# Copy this file to .env and fill in your real values.
# Never commit .env to version control.
#
# Add a new numbered block for each additional account
# and mirror the entry in config.yaml's clients list.

# ── Bybit ────────────────────────────────────────────────
BYBIT_1_API_KEY=your_bybit_account1_api_key
BYBIT_1_API_SECRET=your_bybit_account1_api_secret

# BYBIT_2_API_KEY=your_bybit_account2_api_key
# BYBIT_2_API_SECRET=your_bybit_account2_api_secret

# Bybit Demo Trading keys (api-demo.bybit.com) — paper "prop-firm" account.
# Create from bybit.com → Demo Trading. Used by the `demo: true` client.
BYBIT_TEST_API_KEY=your_bybit_demo_api_key
BYBIT_TEST_API_SECRET=your_bybit_demo_api_secret

# ── Binance ──────────────────────────────────────────────
BINANCE_1_API_KEY=your_binance_account1_api_key
BINANCE_1_API_SECRET=your_binance_account1_api_secret

# BINANCE_2_API_KEY=your_binance_account2_api_key
# BINANCE_2_API_SECRET=your_binance_account2_api_secret

# ── Kraken ───────────────────────────────────────────────
KRAKEN_1_API_KEY=your_kraken_account1_api_key
KRAKEN_1_API_SECRET=your_kraken_account1_api_secret

# KRAKEN_2_API_KEY=your_kraken_account2_api_key
# KRAKEN_2_API_SECRET=your_kraken_account2_api_secret

# ── Admin token ──────────────────────────────────────────
# Gates the sensitive HTTP endpoints (/signal/run, /state, /test/rebalance,
# /report/now, /admin/equity/reset). Passed via Authorization: Bearer <t>,
# the X-Token header, or ?token=. If unset, those endpoints fail closed.
# Generate with: openssl rand -hex 32   (config key name is still server.webhook_token)
WEBHOOK_TOKEN=your_random_token_here

# ── Dashboard auth ───────────────────────────────────────
# SECRET_KEY signs the session cookie — MUST be high-entropy random, NOT a
# guessable phrase (a weak key lets anyone forge a valid session).
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=your_random_48_byte_secret
DASHBOARD_PASSWORD=your_dashboard_password
# Local dev only: serve the dashboard with NO auth when the two vars above are
# unset. Ignored on fly.io (production always fails closed). Leave unset normally.
# ALLOW_OPEN_DASHBOARD=1

# ── Telegram ─────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
# Numeric Telegram user id(s) allowed to issue trade commands (comma-separated).
# For a private 1:1 chat this equals TELEGRAM_CHAT_ID. If unset, commands are
# accepted from ANY sender in the chat — set it to lock trading to yourself.
TELEGRAM_ALLOWED_USER_IDS=your_telegram_user_id
